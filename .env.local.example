NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Cloudflare Turnstile Keys - REPLACE THESE WITH YOUR ACTUAL KEYS
NEXT_PUBLIC_TURNSTILE_SITE_KEY=YOUR_SITE_KEY_HERE
TURNSTILE_SECRET_KEY=YOUR_SECRET_KEY_HERE

# PayPal Credentials
PAYPAL_CLIENT_ID=YOUR_PAYPAL_CLIENT_ID_HERE
PAYPAL_CLIENT_SECRET=YOUR_PAYPAL_CLIENT_SECRET_HERE
# Public client ID used by the browser SDK (must match the same PayPal app)
NEXT_PUBLIC_PAYPAL_CLIENT_ID=YOUR_PAYPAL_CLIENT_ID_HERE

# Optional: force sandbox or live regardless of NODE_ENV (values: sandbox | live)
# PAYPAL_ENV=sandbox
PAYPAL_ENV=sandbox # or "live" for production

# Postmark API Token (for email notifications)
POSTMARK_API_TOKEN=YOUR_POSTMARK_API_TOKEN_HERE

# Google Merchant API
GOOGLE_MERCHANT_ACCOUNT_ID=
GOOGLE_MERCHANT_SERVICE_ACCOUNT_EMAIL=
GOOGLE_MERCHANT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
GOOGLE_MERCHANT_DEVELOPER_EMAIL=
GOOGLE_MERCHANT_DATA_SOURCE_NAME=Dropskey API Products
GOOGLE_MERCHANT_FEED_LABEL=SA
GOOGLE_MERCHANT_CONTENT_LANGUAGE=en
GOOGLE_MERCHANT_TARGET_COUNTRIES=SA
GOOGLE_MERCHANT_CURRENCY=USD
GOOGLE_MERCHANT_BRAND=Dropskey
GOOGLE_MERCHANT_GOOGLE_PRODUCT_CATEGORY=Software > Computer Software
